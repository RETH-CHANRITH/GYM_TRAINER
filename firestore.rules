rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role in ['admin', 'super_admin'] ||
        userRole() in ['admin', 'super_admin']
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Favourites sub-collection — owner only
      match /favourites/{trainerId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Trainer Profiles & Reviews ──────────────────────────────────────────
    match /trainerProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Trainer Posts ───────────────────────────────────────────────────────
    match /trainerPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.trainerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.trainerId == request.auth.uid || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount', 'commentsCount']))
      );
      allow delete: if isSignedIn() && (resource.data.trainerId == request.auth.uid || isAdmin());

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          get(/databases/$(database)/documents/trainerPosts/$(postId)).data.trainerId == request.auth.uid || 
          isAdmin()
        );
        allow update: if isSignedIn() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount', 'repliesCount'])
        );

        // Replies subcollection
        match /replies/{replyId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow delete: if isSignedIn() && (
            resource.data.userId == request.auth.uid || 
            get(/databases/$(database)/documents/trainerPosts/$(postId)).data.trainerId == request.auth.uid || 
            isAdmin()
          );
          allow update: if false;
        }
      }
    }

    // ── Trainer applications ───────────────────────────────────────────────
    match /trainerApplications/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Promotions & Campaigns ──────────────────────────────────────────────
    match /promotions/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.trainerId == request.auth.uid);
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.trainerId == request.auth.uid);
    }

    // ── Bookings ───────────────────────────────────────────────────────────
    match /bookings/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          resource.data.trainerId == request.auth.uid
        )
      );
      allow delete: if isAdmin();
    }

    // ── Transactions — users can read/write their own ──────────────────────
    match /transactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Notifications — per-user sub-collection ────────────────────────────
    match /notifications/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /items/{notifId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() || isAdmin();
      }
    }

    // ── Conversations (messaging) ──────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isSignedIn() && (
        convId.matches('.*' + request.auth.uid + '.*') ||
        (resource != null && 'participantIds' in resource.data && request.auth.uid in resource.data.participantIds)
      );
      allow create: if isSignedIn() && (
        convId.matches('.*' + request.auth.uid + '.*') ||
        (request.resource != null && 'participantIds' in request.resource.data && request.auth.uid in request.resource.data.participantIds)
      );
      allow update: if isSignedIn() && (
        convId.matches('.*' + request.auth.uid + '.*') ||
        (resource != null && 'participantIds' in resource.data && request.auth.uid in resource.data.participantIds)
      );
      allow delete: if isAdmin();

      // Messages sub-collection
      match /messages/{msgId} {
        allow read: if isSignedIn() && convId.matches('.*' + request.auth.uid + '.*');
        allow create: if isSignedIn() &&
          convId.matches('.*' + request.auth.uid + '.*') &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
        allow delete: if isSignedIn() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
    }

    // ── Support & admin-only collections ──────────────────────────────────
    match /supportTickets/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /reports/{id} {
      allow read, write: if isAdmin();
    }

    match /payouts/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.trainerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.trainerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /refunds/{id} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.trainerId == request.auth.uid));
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /gdprRequests/{id} {
      allow read, write: if isAdmin();
    }

    // Immutable admin audit logs — append-only by admin.
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Secure by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
